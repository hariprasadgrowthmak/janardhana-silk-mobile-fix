{% style %}
.koozy-announcement-bar {
  background-color: {{ section.settings.bg_color }};
  color: {{ section.settings.text_color }};
  overflow: hidden;
  font-family: {{ section.settings.font_family }};
}

.koozy-marquee {
  display: flex;
  white-space: nowrap;
  padding-top: {{ section.settings.padding_y }}px;
  padding-bottom: {{ section.settings.padding_y }}px;
  animation: koozy-marquee {{ section.settings.speed }}s linear infinite;
}

{% if section.settings.pause_hover %}
.koozy-marquee:hover {
  animation-play-state: paused;
}
{% endif %}

.koozy-marquee-content {
  display: flex;
  align-items: center;
  gap: {{ section.settings.gap }}px;
  padding: 0 {{ section.settings.padding_x }}px;
  font-size: {{ section.settings.font_size }}px;
  letter-spacing: {{ section.settings.letter_spacing }}em;
}

.koozy-separator {
  opacity: {{ section.settings.separator_opacity }};
}

@keyframes koozy-marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
{% endstyle %}

<div class="koozy-announcement-bar">
  <div class="koozy-marquee">
    
    {% for i in (1..2) %}
      <div class="koozy-marquee-content">
        {% for block in section.blocks %}
          <span>{{ block.settings.text }}</span>
          {% unless forloop.last %}
            <span class="koozy-separator">{{ section.settings.separator }}</span>
          {% endunless %}
        {% endfor %}
      </div>
    {% endfor %}
    
  </div>
</div>

{% schema %}
{
  "name": "Koozy Announcement Bar",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#6A50A1"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "font_family",
      "label": "Font family",
      "default": "'DM Sans', sans-serif"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "label": "Font size",
      "default": 14
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "min": 0,
      "max": 0.2,
      "step": 0.1,
      "label": "Letter spacing",
      "default": 0.1
    },
    {
      "type": "range",
      "id": "padding_y",
      "min": 4,
      "max": 20,
      "step": 1,
      "label": "Vertical padding",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_x",
      "min": 8,
      "max": 40,
      "step": 1,
      "label": "Horizontal padding",
      "default": 16
    },
    {
      "type": "range",
      "id": "gap",
      "min": 8,
      "max": 40,
      "step": 2,
      "label": "Gap between items",
      "default": 32
    },
    {
      "type": "range",
      "id": "speed",
      "min": 5,
      "max": 60,
      "step": 1,
      "label": "Scroll speed (seconds)",
      "default": 20
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator symbol",
      "default": "•"
    },
    {
      "type": "range",
      "id": "separator_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "Separator opacity",
      "default": 0.5
    },
    {
      "type": "checkbox",
      "id": "pause_hover",
      "label": "Pause on hover",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Message",
          "default": "✨ Free Shipping on Orders Above ₹999"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Koozy Announcement Bar",
      "blocks": [
        { "type": "message", "settings": { "text": "✨ Free Shipping on Orders Above ₹999" } },
        { "type": "message", "settings": { "text": "🌿 100% Cotton Comfort" } },
        { "type": "message", "settings": { "text": "💜 Easy 7-Day Returns" } },
        { "type": "message", "settings": { "text": "🧸 Made with Love & Comfort" } },
        { "type": "message", "settings": { "text": "🌸 New Arrivals Every Week" } }
      ]
    }
  ]
}
{% endschema %}