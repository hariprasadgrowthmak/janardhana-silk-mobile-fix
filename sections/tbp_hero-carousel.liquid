{% schema %}
{
  "name": "Advanced Auto Slider",
  "settings": [
    {
      "type": "range",
      "id": "slide_speed",
      "label": "Auto Slide Speed (seconds)",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show Arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show Dots",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Auto Sliding Banner (Des + Mob)",
      "blocks": [{ "type": "slide" }]
    }
  ]
}
{% endschema %}

<section class="auto-slider"
  data-speed="{{ section.settings.slide_speed | times: 1000 }}">

  <div class="slider-wrapper">

    {% if section.settings.show_arrows %}
      <button class="slider-arrow prev">‹</button>
    {% endif %}

    <div class="slider-track">
      {% for block in section.blocks %}
        <div class="slide">
          <picture>
            {% if block.settings.mobile_image %}
              <source media="(max-width: 768px)"
                srcset="{{ block.settings.mobile_image | image_url: width: 1000 }}">
            {% endif %}
            {% if block.settings.desktop_image %}
              <img
                src="{{ block.settings.desktop_image | image_url: width: 2000 }}"
                alt="Slide {{ forloop.index }}"
                loading="lazy">
            {% endif %}
          </picture>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.show_arrows %}
      <button class="slider-arrow next">›</button>
    {% endif %}

  </div>

  {% if section.settings.show_dots %}
    <div class="slider-dots">
      {% for block in section.blocks %}
        <span class="dot{% if forloop.first %} active{% endif %}"
              data-index="{{ forloop.index0 }}"></span>
      {% endfor %}
    </div>
  {% endif %}
</section>

<style>
.auto-slider {
  width: 100%;
  overflow: hidden;
  position: relative;
}


.slider-wrapper {
  position: relative;
}

.slider-track {
  display: flex;
  transition: transform 0.7s ease-in-out;
}

{% comment %} .slide {
  min-width: 100%;
}

.slide img {
  width: 100%;
  height: auto;
  display: block;
} {% endcomment %}
.slide {
  min-width: 100%;
}

.slide img {
  width: calc(100% - 180px); /* 40px left + 40px right */
  margin: 0 90px;
  height: auto;
  display: block;
  {% comment %} border-radius: 12px; {% endcomment %}
}
/* Arrows */
.slider-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(0,0,0,0.45);
  color: #fff;
  border: none;
  width: 42px;
  height: 42px;
  font-size: 28px;
  cursor: pointer;
  z-index: 5;
  border-radius: 50%;
}

.slider-arrow.prev { left: 15px; }
.slider-arrow.next { right: 15px; }

/* Dots */
.slider-dots {
  text-align: center;
  margin-top: 10px;
}

.slider-dots .dot {
  width: 10px;
  height: 10px;
  background: #ccc;
  display: inline-block;
  margin: 0 5px;
  border-radius: 50%;
  cursor: pointer;
}

.slider-dots .dot.active {
  background: #000;
}

@media (max-width: 768px) {
  .slide img {
    width: calc(100% - 30px);
    margin: 0 15px;
  }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const slider = document.querySelector(".auto-slider");
  if (!slider) return;

  const track = slider.querySelector(".slider-track");
  const slides = Array.from(track.children);
  const dots = slider.querySelectorAll(".dot");
  const prev = slider.querySelector(".prev");
  const next = slider.querySelector(".next");
  const speed = parseInt(slider.dataset.speed, 10);

  let index = 1;
  let startX = 0;

  /* Clone slides */
  const firstClone = slides[0].cloneNode(true);
  const lastClone = slides[slides.length - 1].cloneNode(true);

  track.appendChild(firstClone);
  track.insertBefore(lastClone, slides[0]);

  const allSlides = track.querySelectorAll(".slide");

  track.style.transform = `translateX(-100%)`;

  function updateDots() {
    dots.forEach(d => d.classList.remove("active"));
    let realIndex = index - 1;
    if (realIndex < 0) realIndex = dots.length - 1;
    if (realIndex >= dots.length) realIndex = 0;
    dots[realIndex]?.classList.add("active");
  }

  function move() {
    track.style.transition = "transform 0.7s ease";
    track.style.transform = `translateX(-${index * 100}%)`;
    updateDots();
  }

  function nextSlide() {
    index++;
    move();
  }

  function prevSlide() {
    index--;
    move();
  }

  track.addEventListener("transitionend", () => {
    if (index === 0) {
      track.style.transition = "none";
      index = allSlides.length - 2;
      track.style.transform = `translateX(-${index * 100}%)`;
    }

    if (index === allSlides.length - 1) {
      track.style.transition = "none";
      index = 1;
      track.style.transform = `translateX(-${index * 100}%)`;
    }
  });

  let auto = setInterval(nextSlide, speed);

  next && next.addEventListener("click", () => {
    clearInterval(auto);
    nextSlide();
    auto = setInterval(nextSlide, speed);
  });

  prev && prev.addEventListener("click", () => {
    clearInterval(auto);
    prevSlide();
    auto = setInterval(nextSlide, speed);
  });

  dots.forEach((dot, i) => {
    dot.addEventListener("click", () => {
      clearInterval(auto);
      index = i + 1;
      move();
      auto = setInterval(nextSlide, speed);
    });
  });

  /* Swipe */
  track.addEventListener("touchstart", e => {
    startX = e.touches[0].clientX;
  });

  track.addEventListener("touchend", e => {
    const endX = e.changedTouches[0].clientX;
    const diff = startX - endX;
    if (diff > 50) nextSlide();
    if (diff < -50) prevSlide();
  });
});
</script>

