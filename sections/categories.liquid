{% schema %}
{
  "name": "Koozy Categories Ultimate",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Shop by Category"
    },
    {
      "type": "select",
      "id": "desktop_columns",
      "label": "Desktop Columns",
      "default": "3",
      "options": [
        { "value": "2", "label": "2 Columns" },
        { "value": "3", "label": "3 Columns" },
        { "value": "4", "label": "4 Columns" }
      ]
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Mobile Columns",
      "default": "1",
      "options": [
        { "value": "1", "label": "1 Column" },
        { "value": "2", "label": "2 Columns" }
      ]
    },
    {
      "type": "checkbox",
      "id": "enable_hover_overlay",
      "label": "Enable Hover Overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "hover_overlay_color",
      "label": "Hover Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "hover_overlay_opacity",
      "label": "Hover Overlay Opacity (%)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Item",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Category Image" },
        { "type": "text", "id": "title", "label": "Category Title", "default": "Category Name" },
        { "type": "textarea", "id": "description", "label": "Category Description", "default": "Short description about this category." },
        { "type": "url", "id": "link", "label": "Category Link" },
        { "type": "checkbox", "id": "show_badge", "label": "Show Badge", "default": false },
        { "type": "text", "id": "badge_text", "label": "Badge Text", "default": "Coming Soon" },
        { "type": "color", "id": "badge_bg", "label": "Badge Background", "default": "#FEDEC3" },
        { "type": "color", "id": "badge_text_color", "label": "Badge Text Color", "default": "#333333" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Koozy Categories Ultimate",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}


<section style="padding:80px 0; background:#FCFCFC;">
  <div class="container">

    <!-- Section Heading -->
    <div class="text-center mb-5">
      <h2 style="
        font-size:40px;
        font-weight:600;
        color:#222;
      ">
        {{ section.settings.heading }}
      </h2>
    </div>

    <div class="row justify-content-center">

      {% assign desktop_col = 12 | divided_by: section.settings.desktop_columns %}
      {% assign mobile_col = 12 | divided_by: section.settings.mobile_columns %}

      {% for block in section.blocks %}
      <div class="col-{{ mobile_col }} col-md-{{ desktop_col }} mb-4 d-flex justify-content-center">

        <a href="{{ block.settings.link }}"
           style="
           position:relative;
           width:100%;
           max-width:350px;
           overflow:hidden;
           border-radius:25px;
           display:block;
           aspect-ratio:3/4;
           text-decoration:none;
           "
           class="category-card"
           {{ block.shopify_attributes }}>

          {% if block.settings.image %}
            <img src="{{ block.settings.image | image_url: width: 1200 }}"
                 alt="{{ block.settings.title }}"
                 style="
                 width:100%;
                 height:100%;
                 object-fit:cover;
                 transition:transform 0.7s ease;
                 ">
          {% endif %}

          <!-- Gradient -->
          <div style="
            position:absolute;
            inset:0;
            background:linear-gradient(to top, rgba(0,0,0,0.6), transparent);
          "></div>

          <!-- Hover Overlay -->
          {% if section.settings.enable_hover_overlay %}
          <div class="hover-overlay"
               style="
               position:absolute;
               inset:0;
               opacity:0;
               transition:0.5s;
               background:rgba(
               {{ section.settings.hover_overlay_color | color_to_rgb | remove: 'rgb(' | remove: ')' }},
               {{ section.settings.hover_overlay_opacity | divided_by: 100.0 }}
               );
               ">
          </div>
          {% endif %}

          <!-- Content -->
          <div style="
            position:absolute;
            bottom:0;
            left:0;
            right:0;
            padding:30px;
            z-index:2;
          ">

            <h3 style="
              font-size:28px;
              color:#fff;
              font-weight:600;
            ">
              {{ block.settings.title }}
            </h3>

            {% if block.settings.description != blank %}
            <p style="
              margin-top:8px;
              font-size:16px;
              color:rgba(255,255,255,0.85);
            ">
              {{ block.settings.description }}
            </p>
            {% endif %}

            {% if block.settings.show_badge %}
            <span style="
              display:inline-block;
              margin-top:15px;
              padding:6px 18px;
              font-size:12px;
              text-transform:uppercase;
              border-radius:30px;
              background:{{ block.settings.badge_bg }};
              color:{{ block.settings.badge_text_color }};
            ">
              {{ block.settings.badge_text }}
            </span>
            {% endif %}

          </div>

        </a>
      </div>
      {% endfor %}

    </div>
  </div>
</section>


<style>
.category-card:hover img {
  transform: scale(1.05);
}

.category-card:hover .hover-overlay {
  opacity: 1 !important;
}

@media(max-width:768px){
  .category-card h3{
    font-size:22px !important;
  }
}
</style>