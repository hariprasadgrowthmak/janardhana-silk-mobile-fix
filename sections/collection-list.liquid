{{ 'section-collection-list.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

<style>
/* ✅ MOBILE: Horizontal Slider */
@media screen and (max-width: 749px) {
  #Slider-{{ section.id }} {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 12px;
    padding-left: 12px;
    -webkit-overflow-scrolling: touch;
  }

  #Slider-{{ section.id }}::-webkit-scrollbar {
    display: none;
  }

  #Slider-{{ section.id }} .collection-list__item {
    min-width: 80%;
    flex: 0 0 auto;
    scroll-snap-align: start;
  }
}

/* ✅ TABLET: 2 items slider */
@media screen and (min-width: 750px) and (max-width: 1024px) {
  #Slider-{{ section.id }} {
    display: flex;
    overflow-x: auto;
    gap: 16px;
  }

  #Slider-{{ section.id }} .collection-list__item {
    min-width: 48%;
    flex: 0 0 auto;
  }
}

/* ✅ DESKTOP: Grid */
@media screen and (min-width: 1025px) {
  #Slider-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
}

/* ✅ General styling */
.collection-list__item {
  list-style: none;
}
</style>

<div class="collection-slider-section">
  <div class="page-width">

    {% if section.settings.title != blank %}
      <div style="text-align:center; margin-bottom:20px;">
        <h2>{{ section.settings.title }}</h2>
        <div>{{ section.settings.description }}</div>
      </div>
    {% endif %}

    <ul id="Slider-{{ section.id }}" class="collection-list">
      {% for block in section.blocks %}
        <li class="collection-list__item">
          {% render 'new-card-collection',
            card_collection: block.settings.collection,
            custom_img: block.settings.custom_img,
            collection_title: block.settings.collection_title,
            button_title: block.settings.button_title,
            button_link: block.settings.button_link
          %}
        </li>
      {% endfor %}
    </ul>

  </div>
</div>

{% schema %}
{
  "name": "Collection Slider",
  "tag": "section",
  "class": "section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop by Fabrics"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "custom_img",
          "label": "Custom Image"
        },
        {
          "type": "text",
          "id": "collection_title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "button_title",
          "label": "Button Text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Slider",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}