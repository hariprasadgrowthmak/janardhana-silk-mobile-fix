{{ 'section-collection-list.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

<style>
/* MOBILE */
@media screen and (max-width: 749px) {
  .auto-slider {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 12px;
    padding-left: 12px;
  }

  .auto-slider::-webkit-scrollbar {
    display: none;
  }

  .auto-slider li {
    min-width: 80%;
    flex: 0 0 auto;
    scroll-snap-align: start;
  }
}

/* TABLET */
@media screen and (min-width: 750px) and (max-width: 1024px) {
  .auto-slider {
    display: flex;
    overflow-x: auto;
    gap: 16px;
  }

  .auto-slider li {
    min-width: 48%;
  }
}

/* DESKTOP */
@media screen and (min-width: 1025px) {
  .auto-slider {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
}
</style>

<div class="page-width">
  
  <h2 style="text-align:center;">Shop by Collections</h2>

  <ul class="auto-slider">

    {% assign my_collections = "wedding,printed-silk-fabrics,woven-silk-fabrics,dyed-silk-fabrics" | split: "," %}

    {% for handle in my_collections %}
      {% assign col = collections[handle] %}

      {% if col != blank %}
        <li>
          {% render 'new-card-collection',
            card_collection: col,
            collection_title: col.title,
            button_title: "Shop Now",
            button_link: col.url
          %}
        </li>
      {% endif %}

    {% endfor %}

  </ul>

</div>

{% schema %}
{
  "name": "Auto Collection Slider",
  "settings": [],
  "presets": [
    {
      "name": "Auto Collection Slider"
    }
  ]
}
{% endschema %}