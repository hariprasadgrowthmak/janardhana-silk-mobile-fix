<section 
  class="offer-cta relative overflow-hidden"
  style="
    background-color: {{ section.settings.bg_color }};
    --primary: {{ section.settings.primary_color }};
    --secondary: {{ section.settings.secondary_color }};
    --foreground: {{ section.settings.foreground_color }};
    --muted: {{ section.settings.muted_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>

  {% if section.settings.show_blobs %}
  <!-- Background Blobs -->
  <div class="absolute top-0 right-0 -mt-10 -mr-10 w-64 h-64 rounded-full blur-3xl"
       style="background: rgba(255,255,255,0.1);"></div>

  <div class="absolute bottom-0 left-0 -mb-10 -ml-10 w-64 h-64 rounded-full blur-3xl"
       style="background: var(--secondary); opacity: 0.2;"></div>
  {% endif %}

  <div class="relative max-w-7xl mx-auto px-4 md:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8 md:gap-12">

      <!-- LEFT CONTENT -->
      <div class="text-center md:text-left max-w-2xl" style="color: #fff;">
        
        {% if section.settings.badge_text != blank %}
        <div class="inline-block mb-4 px-4 py-1 rounded-full text-sm font-medium tracking-wider uppercase backdrop-blur-sm"
             style="background: rgba(255,255,255,0.2);">
          {{ section.settings.badge_text }}
        </div>
        {% endif %}

        {% if section.settings.heading != blank %}
        <h2 class="text-4xl md:text-6xl font-bold mb-4 leading-tight">
          {{ section.settings.heading }}
        </h2>
        {% endif %}

        {% if section.settings.description != blank %}
        <p class="text-lg mb-8 leading-relaxed" style="color: rgba(255,255,255,0.8);">
          {{ section.settings.description }}
        </p>
        {% endif %}

        <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
          
          {% if section.settings.button1_text != blank %}
          <a href="{{ section.settings.button1_link }}"
             class="px-8 py-4 rounded-full font-bold text-sm tracking-wider uppercase shadow-lg transition-all hover:-translate-y-1"
             style="background: var(--secondary); color: var(--primary);">
            {{ section.settings.button1_text }}
          </a>
          {% endif %}

          {% if section.settings.button2_text != blank %}
          <a href="{{ section.settings.button2_link }}"
             class="px-8 py-4 rounded-full font-bold text-sm tracking-wider uppercase border-2 transition-all"
             style="border-color: #fff; color: #fff;">
            {{ section.settings.button2_text }}
          </a>
          {% endif %}

        </div>
      </div>

      <!-- RIGHT BADGE -->
      <div class="relative w-full md:w-1/3 flex justify-center md:justify-end">
        <div class="{% if section.settings.enable_animation %}animate-float{% endif %} relative">

          <div class="w-64 h-64 md:w-80 md:h-80 bg-white rounded-full flex items-center justify-center shadow-2xl relative z-10">
            <div class="text-center">
              <span class="block text-6xl md:text-7xl font-bold mb-2"
                    style="color: var(--primary);">
                {{ section.settings.discount_percentage }}
              </span>

              <span class="block text-xl font-semibold uppercase tracking-widest"
                    style="color: var(--foreground);">
                {{ section.settings.discount_label }}
              </span>

              <span class="block text-xs mt-2"
                    style="color: var(--muted);">
                {{ section.settings.discount_subtext }}
              </span>
            </div>
          </div>

          <!-- Decorative circle -->
          <div class="absolute inset-0 rounded-full transform scale-90 opacity-50 z-0 translate-x-4 translate-y-4"
               style="background: var(--secondary);"></div>

        </div>
      </div>

    </div>
  </div>
</section>

<style>
@keyframes float {
  0% { transform: translateY(0px); }
  50% { transform: translateY(-10px); }
  100% { transform: translateY(0px); }
}
.animate-float {
  animation: float 4s ease-in-out infinite;
}
</style>

{% schema %}
{
  "name": "Offer CTA - Koozy",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Top Badge Text",
      "default": "Limited Time Offer"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get 15% Off Your First Order!"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Join the Koozy Club today and unlock exclusive access to new drops and a welcome discount."
    },
    {
      "type": "text",
      "id": "discount_percentage",
      "label": "Discount Percentage",
      "default": "15%"
    },
    {
      "type": "text",
      "id": "discount_label",
      "label": "Discount Label",
      "default": "OFF"
    },
    {
      "type": "text",
      "id": "discount_subtext",
      "label": "Discount Subtext",
      "default": "On all styles"
    },
    {
      "type": "text",
      "id": "button1_text",
      "label": "Primary Button Text",
      "default": "Claim My Discount"
    },
    {
      "type": "url",
      "id": "button1_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "button2_text",
      "label": "Secondary Button Text",
      "default": "Shop Collection"
    },
    {
      "type": "url",
      "id": "button2_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#6A50A1"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary Color",
      "default": "#6A50A1"
    },
    {
      "type": "color",
      "id": "secondary_color",
      "label": "Secondary Color",
      "default": "#F4D7E8"
    },
    {
      "type": "color",
      "id": "foreground_color",
      "label": "Foreground Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted Text Color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 20,
      "max": 200,
      "step": 10,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 20,
      "max": 200,
      "step": 10,
      "default": 80
    },
    {
      "type": "checkbox",
      "id": "show_blobs",
      "label": "Show Background Blur Effects",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Enable Floating Animation",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Offer CTA - Koozy"
    }
  ]
}
{% endschema %}