{% schema %}
{
  "name": "Auto Height Desmob",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image"
    }
  ],
  "presets": [
    {
      "name": "Auto Height Desktop + Mobile Banner"
    }
  ]
}
{% endschema %}

<section class="auto-banner">
  <picture>
    {% if section.settings.mobile_image %}
      <source
        srcset="{{ section.settings.mobile_image | image_url: width: 1000 }}"
        media="(max-width: 768px)">
    {% endif %}

    {% if section.settings.desktop_image %}
      <img 
        src="{{ section.settings.desktop_image | image_url: width: 2000 }}"
        alt="Banner"
        class="banner-img"
        loading="lazy">
    {% endif %}
  </picture>
</section>

<style>
.auto-banner {
  width: 100%;
}

.auto-banner img {
  width: 100%;
  height: auto; /* AUTO HEIGHT */
  display: block;
}
</style>
