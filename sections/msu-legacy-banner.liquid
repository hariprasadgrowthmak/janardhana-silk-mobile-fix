{{ 'msu-sections.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .msu-legacy-section-{{ section.id }} {
    {% if section.settings.image != blank %}
      background-image: url('{{ section.settings.image | image_url: width: 1920 }}');
    {% endif %}
    background-color: {{ section.settings.bg_color }};
    min-height: {{ section.settings.section_height }}px;
  }
  @media screen and (max-width: 749px) {
    .msu-legacy-section-{{ section.id }} {
      min-height: {{ section.settings.section_height | times: 0.6 | round: 0 }}px;
    }
  }
{%- endstyle -%}

<div class="msu-legacy-section msu-legacy-section-{{ section.id }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  <div class="msu-legacy-overlay">
    <div class="page-width msu-legacy-content-wrapper">
      <div class="msu-legacy-content msu-legacy-content--{{ section.settings.content_position }}">
        {%- if section.settings.legacy_label != blank -%}
          <span class="msu-legacy-label">{{ section.settings.legacy_label }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="msu-legacy-heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="msu-legacy-text rte">{{ section.settings.text }}</div>
        {%- endif -%}

        {%- if section.settings.show_review_widget -%}
          <div class="msu-legacy-review-widget">
            <div class="msu-review-stars">
              {%- assign full_stars = section.settings.star_rating | floor -%}
              {%- for i in (1..full_stars) -%}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="#FFB800"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {%- endfor -%}
              {%- assign has_half = section.settings.star_rating | modulo: 1 -%}
              {%- if has_half > 0 -%}
                <svg width="20" height="20" viewBox="0 0 24 24"><defs><linearGradient id="half-{{ section.id }}"><stop offset="50%" stop-color="#FFB800"/><stop offset="50%" stop-color="#ccc"/></linearGradient></defs><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="url(#half-{{ section.id }})"/></svg>
              {%- endif -%}
            </div>
            <div class="msu-review-info">
              <span class="msu-review-rating">{{ section.settings.star_rating }}/5</span>
              <span class="msu-review-count">{{ section.settings.review_count }} Reviews</span>
            </div>
            {%- if section.settings.review_button_label != blank -%}
              <a href="{{ section.settings.review_button_link }}" class="msu-review-btn">
                {{ section.settings.review_button_label }}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="msu-legacy-btn button">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "MSU Brand Legacy Banner",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fallback background color",
      "default": "#42120F"
    },
    {
      "type": "range",
      "id": "section_height",
      "min": 200,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Section height",
      "default": 500
    },
    {
      "type": "text",
      "id": "legacy_label",
      "label": "Legacy label",
      "default": "40+ Years of Legacy"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Weaving Traditions Since 1984"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body text",
      "default": "<p>A legacy of exquisite craftsmanship and heritage weaving that has defined elegance for generations.</p>"
    },
    {
      "type": "select",
      "id": "content_position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left",
      "label": "Content position"
    },
    {
      "type": "checkbox",
      "id": "show_review_widget",
      "label": "Show review widget",
      "default": true
    },
    {
      "type": "text",
      "id": "star_rating",
      "label": "Star rating (e.g. 4.6)",
      "default": "4.6"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review count",
      "default": "9000+"
    },
    {
      "type": "text",
      "id": "review_button_label",
      "label": "Review button label",
      "default": "Review Now"
    },
    {
      "type": "url",
      "id": "review_button_link",
      "label": "Review button link"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "MSU Brand Legacy Banner"
    }
  ]
}
{% endschema %}
