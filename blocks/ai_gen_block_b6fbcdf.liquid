{% doc %}
  @prompt
    collage
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collage-container-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-collage-grid-{{ ai_gen_id }} {
    display: grid;
    gap: {{ block.settings.gap }}px;
    width: 100%;
  }

  .ai-collage-grid-{{ ai_gen_id }}--layout-1 {
    grid-template-columns: 2fr 1fr;
    grid-template-rows: repeat(2, 1fr);
  }

  .ai-collage-grid-{{ ai_gen_id }}--layout-2 {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: repeat(2, 1fr);
  }

  .ai-collage-grid-{{ ai_gen_id }}--layout-3 {
    grid-template-columns: 1fr 2fr;
    grid-template-rows: repeat(2, 1fr);
  }

  .ai-collage-grid-{{ ai_gen_id }}--layout-4 {
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(2, 1fr);
  }

  .ai-collage-item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    background-color: {{ block.settings.placeholder_bg_color }};
  }

  .ai-collage-grid-{{ ai_gen_id }}--layout-1 .ai-collage-item-{{ ai_gen_id }}:first-child {
    grid-row: 1 / 3;
  }

  .ai-collage-grid-{{ ai_gen_id }}--layout-3 .ai-collage-item-{{ ai_gen_id }}:last-child {
    grid-row: 1 / 3;
  }

  .ai-collage-grid-{{ ai_gen_id }}--layout-4 .ai-collage-item-{{ ai_gen_id }}:first-child {
    grid-column: 1 / 3;
  }

  .ai-collage-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: {{ block.settings.min_height }}px;
  }

  .ai-collage-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-collage-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: {{ block.settings.min_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.placeholder_bg_color }};
  }

  .ai-collage-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-collage-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, {{ block.settings.overlay_opacity | divided_by: 100.0 }}) 100%
    );
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: {{ block.settings.text_padding }}px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  {% if block.settings.show_overlay_on_hover %}
    .ai-collage-item-{{ ai_gen_id }}:hover .ai-collage-overlay-{{ ai_gen_id }} {
      opacity: 1;
    }
  {% else %}
    .ai-collage-overlay-{{ ai_gen_id }} {
      opacity: 1;
    }
  {% endif %}

  .ai-collage-title-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    margin: 0 0 8px 0;
    line-height: 1.2;
  }

  .ai-collage-description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.description_size }}px;
    margin: 0;
    line-height: 1.4;
  }

  .ai-collage-link-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-collage-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr !important;
      grid-template-rows: auto !important;
    }

    .ai-collage-item-{{ ai_gen_id }} {
      grid-row: auto !important;
      grid-column: auto !important;
    }

    .ai-collage-image-wrapper-{{ ai_gen_id }},
    .ai-collage-placeholder-{{ ai_gen_id }} {
      min-height: {{ block.settings.mobile_min_height }}px;
    }
  }
{% endstyle %}

<collage-block-{{ ai_gen_id }}
  class="ai-collage-container-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-collage-grid-{{ ai_gen_id }} ai-collage-grid-{{ ai_gen_id }}--layout-{{ block.settings.layout }}">
    {% for i in (1..5) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign title_key = 'title_' | append: i
        assign description_key = 'description_' | append: i
        assign link_key = 'link_' | append: i

        assign image = block.settings[image_key]
        assign title = block.settings[title_key]
        assign description = block.settings[description_key]
        assign link = block.settings[link_key]

        if block.settings.layout == '4' and i > 4
          break
        endif
        if block.settings.layout != '4' and i > 3
          break
        endif
      %}

      <div class="ai-collage-item-{{ ai_gen_id }}">
        {% if image %}
          <div class="ai-collage-image-wrapper-{{ ai_gen_id }}">
            <img
              src="{{ image | image_url: width: 1000 }}"
              alt="{{ image.alt | escape }}"
              class="ai-collage-image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ image.width }}"
              height="{{ image.height }}"
            >
          </div>
        {% else %}
          <div class="ai-collage-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if title != blank or description != blank %}
          <div class="ai-collage-overlay-{{ ai_gen_id }}">
            {% if title != blank %}
              <h3 class="ai-collage-title-{{ ai_gen_id }}">{{ title }}</h3>
            {% endif %}
            {% if description != blank %}
              <p class="ai-collage-description-{{ ai_gen_id }}">{{ description }}</p>
            {% endif %}
          </div>
        {% endif %}

        {% if link != blank %}
          <a
            href="{{ link }}"
            class="ai-collage-link-{{ ai_gen_id }}"
            aria-label="{% if title != blank %}{{ title }}{% else %}View image {{ i }}{% endif %}"
          ></a>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</collage-block-{{ ai_gen_id }}>

<script>
  (function() {
    class CollageBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.adjustImageHeights();
        window.addEventListener('resize', () => this.adjustImageHeights());
      }

      adjustImageHeights() {
        if (window.innerWidth > 749) {
          const items = this.querySelectorAll('.ai-collage-item-{{ ai_gen_id }}');
          items.forEach(item => {
            const wrapper = item.querySelector('.ai-collage-image-wrapper-{{ ai_gen_id }}');
            if (wrapper) {
              wrapper.style.minHeight = '{{ block.settings.min_height }}px';
            }
          });
        }
      }
    }

    customElements.define('collage-block-{{ ai_gen_id }}', CollageBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
