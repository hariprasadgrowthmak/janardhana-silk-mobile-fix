{% doc %}
  @prompt
    divider
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-divider-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    margin: {{ block.settings.spacing_top }}px auto {{ block.settings.spacing_bottom }}px;
  }

  .ai-divider-line-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.thickness }}px;
    background-color: {{ block.settings.color }};
    border: none;
    margin: 0;
    {% if block.settings.style == 'dashed' %}
      background: repeating-linear-gradient(
        to right,
        {{ block.settings.color }} 0px,
        {{ block.settings.color }} {{ block.settings.dash_length }}px,
        transparent {{ block.settings.dash_length }}px,
        transparent {{ block.settings.dash_length | plus: block.settings.dash_gap }}px
      );
    {% elsif block.settings.style == 'dotted' %}
      background: repeating-linear-gradient(
        to right,
        {{ block.settings.color }} 0px,
        {{ block.settings.color }} {{ block.settings.thickness }}px,
        transparent {{ block.settings.thickness }}px,
        transparent {{ block.settings.thickness | times: 2 | plus: block.settings.dot_gap }}px
      );
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-divider-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-divider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <hr class="ai-divider-line-{{ ai_gen_id }}">
</div>

{% schema %}
{
  "name": "Divider",
  "settings": [
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "style",
      "label": "Style",
      "options": [
        {
          "value": "solid",
          "label": "Solid"
        },
        {
          "value": "dashed",
          "label": "Dashed"
        },
        {
          "value": "dotted",
          "label": "Dotted"
        }
      ],
      "default": "solid"
    },
    {
      "type": "range",
      "id": "thickness",
      "label": "Thickness",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "dash_length",
      "label": "Dash length",
      "min": 5,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "dash_gap",
      "label": "Dash gap",
      "min": 5,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "dot_gap",
      "label": "Dot gap",
      "min": 2,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "spacing_top",
      "label": "Spacing top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "label": "Spacing bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Divider"
    }
  ]
}
{% endschema %}
