{% comment %}
  Renders product buy-buttons (FIXED VERSION)
{% endcomment %}

<style>
.custom-blouse-form {
  margin: 20px 0;
}

.custom-blouse-form input,
.custom-blouse-form select {
  width: 100%;
  padding: 10px;
  margin-bottom: 10px;
}
</style>

<div {{ block.shopify_attributes }}>
  {%- if product != blank -%}

    <product-form class="product-form" data-section-id="{{ section.id }}">

      {%- form 'product',
        product,
        id: product_form_id,
        class: 'form',
        novalidate: 'novalidate',
        data-type: 'add-to-cart-form'
      -%}

        <!-- VARIANT -->
        <input
          type="hidden"
          name="id"
          value="{{ product.selected_or_first_available_variant.id }}"
          class="product-variant-id"
        >

        <!-- 🧵 BLOUSE FORM -->
        {% if product.tags contains 'blouse' %}
        <div class="custom-blouse-form">

          <h3>🧵 Blouse Stitching Requirements</h3>

          <label>Blouse Type</label>
          <select name="properties[Blouse Type]">
            <option>Plain Blouse Stitching – ₹1400</option>
          </select>

          <label>
            <input type="checkbox" name="properties[Fall Pico]" value="Yes">
            Add Fall Pico
          </label>

          <hr>

          <h4>Measurements</h4>

          <input type="text" name="properties[Bust]" placeholder="Bust">
          <input type="text" name="properties[Above Waist]" placeholder="Above Waist">
          <input type="text" name="properties[Shoulder]" placeholder="Shoulder">

          <input type="text" name="properties[Blouse Length]" placeholder="Blouse Length">
          <input type="text" name="properties[Sleeve Length]" placeholder="Sleeve Length">

          <input type="text" name="properties[Arm Hole]" placeholder="Arm Hole">
          <input type="text" name="properties[Around Arm]" placeholder="Around Arm">

          <hr>

          <h4>Neck Design</h4>

          <input type="text" name="properties[Front Neck Depth]" placeholder="Front Neck">
          <input type="text" name="properties[Back Neck Depth]" placeholder="Back Neck">

        </div>
        {% endif %}

        <!-- ERROR MESSAGE (IMPORTANT) -->
        <div class="product-form__error-message-wrapper" role="alert" hidden>
          <span class="product-form__error-message"></span>
        </div>

        <!-- BUTTON -->
        <div class="product-form__buttons">

          <button
            type="submit"
            name="add"
            class="product-form__submit button button--full-width button--primary"
          >
            <span>Add to cart</span>

            <!-- LOADING SPINNER (IMPORTANT) -->
            <div class="loading-overlay__spinner hidden">
              <svg
                aria-hidden="true"
                focusable="false"
                class="spinner"
                viewBox="0 0 66 66"
                xmlns="http://www.w3.org/2000/svg"
              >
                <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
              </svg>
            </div>

          </button>

        </div>

        <!-- DYNAMIC CHECKOUT (IMPORTANT) -->
        {%- if block.settings.show_dynamic_checkout -%}
          {{ form | payment_button }}
        {%- endif -%}

      {%- endform -%}

    </product-form>

  {%- else -%}

    <button disabled class="button button--full-width">Sold out</button>

  {%- endif -%}
</div>