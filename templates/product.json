        "custom_liquid_Ea9rLc": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<div id=\"addon-services\" style=\"margin:20px 0;padding:20px;border:2px solid #8B0000;border-radius:10px;background:#FFF8F0;\">\n<h3 style=\"color:#8B0000;margin:0 0 15px;font-size:18px;\">Add Finishing Services</h3>\n\n<div style=\"margin-bottom:12px;\">\n<label style=\"font-weight:bold;display:block;margin-bottom:5px;\">Blouse Stitching</label>\n<select id=\"addon-blouse\" style=\"width:100%;padding:8px;border:1px solid #ccc;border-radius:5px;\">\n<option value=\"\">-- Select --</option>\n<option value=\"45634872606918\">Designer Blouse Stitching (₹1,500)</option>\n<option value=\"45634872639686\">Luxury Blouse Stitching (₹1,000)</option>\n<option value=\"45634872672454\">Premium Blouse Stitching (₹750)</option>\n<option value=\"0\">None of the above</option>\n</select>\n</div>\n\n<div style=\"margin-bottom:12px;\">\n<label style=\"font-weight:bold;display:block;margin-bottom:5px;\">Petticoat Stitching</label>\n<select id=\"addon-petticoat\" style=\"width:100%;padding:8px;border:1px solid #ccc;border-radius:5px;\">\n<option value=\"\">-- Select --</option>\n<option value=\"45634872737990\">Premium Tissue/Satin Petticoat (₹750)</option>\n<option value=\"45634872770758\">Standard Cotton Petticoat (₹500)</option>\n<option value=\"0\">None of the above</option>\n</select>\n</div>\n\n<div style=\"margin-bottom:12px;\">\n<label style=\"font-weight:bold;display:block;margin-bottom:5px;\">Fall & Edge Finish</label>\n<select id=\"addon-fall\" style=\"width:100%;padding:8px;border:1px solid #ccc;border-radius:5px;\">\n<option value=\"\">-- Select --</option>\n<option value=\"45634872836294\">Fall and Edge Finishing (₹200)</option>\n<option value=\"0\">None of the above</option>\n</select>\n</div>\n\n<div style=\"margin-bottom:12px;\">\n<label style=\"font-weight:bold;display:block;margin-bottom:5px;\">Embroidery/Embellish</label>\n<select id=\"addon-embroidery\" style=\"width:100%;padding:8px;border:1px solid #ccc;border-radius:5px;\">\n<option value=\"\">-- Select --</option>\n<option value=\"45634872901830\">Additional Tassels/Knots (₹750)</option>\n<option value=\"0\">None of the above</option>\n</select>\n</div>\n\n<button id=\"addon-add-btn\" onclick=\"addAddonsToCart()\" style=\"width:100%;padding:12px;background:#8B0000;color:white;border:none;border-radius:5px;font-size:16px;font-weight:bold;cursor:pointer;margin-top:10px;\">Add Selected Services to Cart</button>\n<p id=\"addon-msg\" style=\"text-align:center;margin-top:8px;color:green;display:none;font-weight:bold;\">✅ Services added to cart!</p>\n</div>\n\n<script>\nfunction addAddonsToCart(){\n  var ids=['addon-blouse','addon-petticoat','addon-fall','addon-embroidery'];\n  var items=[];\n  ids.forEach(function(id){\n    var v=document.getElementById(id).value;\n    if(v && v!=='' && v!=='0') items.push({id:parseInt(v),quantity:1});\n  });\n  if(items.length===0){\n    document.getElementById('addon-msg').style.display='block';\n    document.getElementById('addon-msg').style.color='#666';\n    document.getElementById('addon-msg').textContent='No services selected.';\n    setTimeout(function(){document.getElementById('addon-msg').style.display='none'},3000);\n    return;\n  }\n  var btn=document.getElementById('addon-add-btn');\n  btn.textContent='Adding...';btn.disabled=true;\n  fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({items:items})})\n  .then(function(r){return r.json()})\n  .then(function(){\n    btn.textContent='Add Selected Services to Cart';btn.disabled=false;\n    document.getElementById('addon-msg').style.color='green';\n    document.getElementById('addon-msg').textContent='✅ Services added to cart!';\n    document.getElementById('addon-msg').style.display='block';\n    setTimeout(function(){document.getElementById('addon-msg').style.display='none'},3000);\n  })\n  .catch(function(){btn.textContent='Add Selected Services to Cart';btn.disabled=false;alert('Error adding to cart');});\n}\n</script>"
          }
