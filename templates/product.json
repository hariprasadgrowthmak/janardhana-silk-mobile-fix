        "custom_liquid_VUxbdy": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% if product.handle == 'pure-handloom-kanjeevaram-silk-saree-al212151' %}\n\n{% assign blouse_product = all_products['blouse-add-on'] %}\n\n{% if blouse_product != blank and blouse_product.variants.size > 0 %}\n\n<div class=\"addon-card\" id=\"addon-blouse-card\" style=\"border:1px solid #eee;padding:12px;border-radius:10px;margin-top:10px;\">\n  \n  <label style=\"display:flex;align-items:center;gap:12px;cursor:pointer;\">\n    \n    <input type=\"checkbox\" id=\"add-blouse-checkbox\" style=\"transform:scale(1.2);cursor:pointer;\">\n\n    {% if blouse_product.featured_image %}\n      <img \n        src=\"{{ blouse_product.featured_image | image_url: width: 120 }}\" \n        width=\"60\" \n        height=\"60\"\n        style=\"border-radius:8px;object-fit:cover;\"\n      >\n    {% endif %}\n\n    <div style=\"flex:1;\">\n      <div style=\"font-weight:600;\">{{ blouse_product.title }}</div>\n      <div id=\"blouse-price\" style=\"color:#666;font-size:14px;\">\n        ₹{{ blouse_product.variants.first.price | divided_by: 100 }}\n      </div>\n    </div>\n\n  </label>\n\n</div>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', function () {\n\n  const form = document.querySelector('form[action*=\\\"/cart/add\\\"]');\n  if (!form) return;\n\n  const checkbox = document.getElementById('add-blouse-checkbox');\n\n  const blouseVariant = {{ blouse_product.variants.first | json }};\n\n  form.addEventListener('submit', function(e){\n\n    if (!checkbox.checked) return;\n\n    e.preventDefault();\n\n    const formData = new FormData(form);\n    const mainVariantId = formData.get('id');\n    const quantity = formData.get('quantity') || 1;\n\n    fetch('/cart/add.js', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({\n        items: [\n          {\n            id: mainVariantId,\n            quantity: quantity,\n            properties: {\n              \"Bundle\": \"Saree + Blouse\"\n            }\n          },\n          {\n            id: blouseVariant.id,\n            quantity: quantity\n          }\n        ]\n      })\n    })\n    .then(() => {\n      window.location.href = '/cart';\n    })\n    .catch(err => {\n      console.error('Addon error:', err);\n      form.submit();\n    });\n\n  });\n\n});\n</script>\n\n{% endif %}\n{% endif %}"
          }
        },
